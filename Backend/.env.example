# ---- Server ----
PORT=8080
# Comma-separated list of allowed origins, or "*" to allow any origin.
CORS_ORIGIN=*

# ---- Database ----
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0

# ---- JWT ----
# Use long, random strings (e.g. `openssl rand -hex 48`).
ACCESS_TOKEN_SECRET=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=replace-with-another-long-random-string
REFRESH_TOKEN_EXPIRY=10d

# ---- Mail (Mailtrap or any SMTP provider) ----
# Leave USER/PASS empty in dev — email sending becomes a no-op and won't crash requests.
MAILTRAP_SMTP_HOST=sandbox.smtp.mailtrap.io
MAILTRAP_SMTP_PORT=2525
MAILTRAP_SMTP_USER=
MAILTRAP_SMTP_PASS=
MAIL_FROM=mail@projectcamp.com

# ---- Frontend base URL used in verification / reset email links ----
FORGOT_PASSWORD_REDIRECT_URL=http://localhost:5173
